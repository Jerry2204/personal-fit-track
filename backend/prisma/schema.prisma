generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  Male
  Female
  Other
}

enum FitnessGoal {
  FatLoss
  MuscleGain
  Maintenance
  Endurance
  Strength
}

enum ActivityLevel {
  Sedentary
  LightlyActive
  ModeratelyActive
  VeryActive
  ExtremelyActive
}

enum WorkoutType {
  Push
  Pull
  Leg
  FullBody
  UpperBody
  LowerBody
  Custom
}

enum MuscleGroup {
  Chest
  Back
  Shoulders
  Biceps
  Triceps
  Legs
  Glutes
  Core
  FullBody
}

enum EquipmentType {
  Barbell
  Dumbbell
  Machine
  Cable
  Bodyweight
  Kettlebell
  Band
  Other
}

enum DifficultyLevel {
  Beginner
  Intermediate
  Advanced
}

enum RunType {
  EasyRun
  RecoveryRun
  TempoRun
  IntervalRun
  LongRun
  Race
}

enum GoalType {
  RunDistance
  WorkoutSessions
  BodyWeight
  Strength
  RunningPace
  Nutrition
  Other
}

enum GoalStatus {
  Active
  Completed
  Failed
}

enum Mood {
  Great
  Good
  Neutral
  Bad
  Terrible
}

enum ActivityType {
  Workout
  Run
  Rest
}

enum PlanDayStatus {
  Pending
  Completed
  Skipped
  Rescheduled
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile        Profile?
  workouts       Workout[]
  runActivities  RunActivity[]
  bodyProgresses BodyProgress[]
  goals          Goal[]
  habitLogs      HabitLog[]
  shoes          Shoe[]
  exercises      Exercise[]
  notifications  Notification[]
  workoutPlans   WorkoutPlan[]

  @@index([email])
}

model Profile {
  id                  String        @id @default(cuid())
  userId              String        @unique
  name                String?
  age                 Int?
  gender              Gender?
  heightCm            Float?
  currentWeightKg     Float?
  avatarUrl           String?
  fitnessGoal         FitnessGoal?
  activityLevel       ActivityLevel?
  targetWeightKg      Float?
  weeklyWorkoutTarget   Int?
  weeklyRunningTargetKm Float?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exercise {
  id             String         @id @default(cuid())
  name           String
  muscleGroup    MuscleGroup
  equipmentType  EquipmentType  @default(Other)
  difficultyLevel DifficultyLevel @default(Beginner)
  instructions   String?
  isCustom       Boolean        @default(false)
  createdByUserId String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  createdBy User?            @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  workoutExercises WorkoutExercise[]

  @@index([muscleGroup])
  @@index([createdByUserId])
}

model Workout {
  id            String     @id @default(cuid())
  userId        String
  date          DateTime   @default(now())
  type          WorkoutType
  durationMinutes Int?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutExercises   WorkoutExercise[]
  planDayActivities  WorkoutPlanDayActivity[]

  @@index([userId])
  @@index([userId, date])
  @@index([date])
}

model WorkoutExercise {
  id         String @id @default(cuid())
  workoutId  String
  exerciseId String
  sortOrder  Int    @default(0)
  notes      String?

  workout Workout     @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  sets     WorkoutSet[]

  @@index([workoutId])
  @@index([exerciseId])
}

model WorkoutSet {
  id                String  @id @default(cuid())
  workoutExerciseId String
  setNumber         Int
  reps              Int?
  weightKg          Float?
  rpe               Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@index([workoutExerciseId])
}

model RunActivity {
  id            String   @id @default(cuid())
  userId        String
  shoeId        String?
  date          DateTime @default(now())
  distanceKm    Float
  durationMinutes Int
  averagePace   Float?
  type          RunType  @default(EasyRun)
  heartRateAvg  Int?
  caloriesEstimate Int?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shoe              Shoe?                   @relation(fields: [shoeId], references: [id], onDelete: SetNull)
  planDayActivities WorkoutPlanDayActivity[]

  @@index([userId])
  @@index([userId, date])
  @@index([date])
  @@index([shoeId])
}

model BodyProgress {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @default(now())
  weightKg        Float?
  bodyFatPercent  Float?
  waistCm         Float?
  chestCm         Float?
  armCm           Float?
  thighCm         Float?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@index([date])
}

model Goal {
  id            String     @id @default(cuid())
  userId        String
  name          String
  type          GoalType
  targetValue   Float
  currentValue  Float      @default(0)
  unit          String?
  deadline      DateTime?
  status        GoalStatus @default(Active)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
}

model HabitLog {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @default(now())
  workoutDone     Boolean?
  runningDone     Boolean?
  steps           Int?
  waterIntakeMl   Int?
  sleepHours      Float?
  bodyWeightKg    Float?
  caloriesIntake  Int?
  proteinG        Float?
  mood            Mood?
  energyLevel     Int?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@index([date])
}

model Shoe {
  id                String   @id @default(cuid())
  userId            String
  brand             String
  model             String
  purchaseDate      DateTime?
  maxMileageKm      Float?
  currentMileageKm  Float    @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  runActivities RunActivity[]

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // goal_reminder, habit_reminder, workout_reminder, achievement, system
  title     String
  message   String
  severity  String   // info, warning, success
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([userId, createdAt])
}

model WorkoutPlan {
  id        String   @id @default(cuid())
  userId    String
  name      String
  startDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  days WorkoutPlanDay[]

  @@index([userId])
  @@index([userId, startDate])
}

model WorkoutPlanDay {
  id            String   @id @default(cuid())
  workoutPlanId String
  dayOfWeek     Int      // 0=Sun, 1=Mon, ..., 6=Sat
  name          String?  // label for the day, e.g. "Push Day"
  notes         String?  // day-level notes
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workoutPlan WorkoutPlan          @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  activities   WorkoutPlanDayActivity[]

  @@index([workoutPlanId])
}

model WorkoutPlanDayActivity {
  id            String        @id @default(cuid())
  workoutPlanDayId String
  sortOrder     Int           @default(0)
  activityType  ActivityType
  name          String?       // e.g. "Morning Push", "Easy Run"
  workoutType   WorkoutType?
  runType       RunType?
  targetDistanceKm Float?
  targetDurationMinutes Int?
  targetPace    Float?
  notes         String?
  status        PlanDayStatus @default(Pending)
  completedDate DateTime?
  workoutId     String?
  runId         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  workoutPlanDay WorkoutPlanDay @relation(fields: [workoutPlanDayId], references: [id], onDelete: Cascade)
  workout        Workout?       @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  run            RunActivity?   @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([workoutPlanDayId])
  @@index([status])
}
